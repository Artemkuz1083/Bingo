SERVICE_NAME=auth-service
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/bingo_auth
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
USER_EVENTS_EXCHANGE=user.events
USER_REGISTERED_ROUTING_KEY=user.registered
USER_REGISTERED_QUEUE=user-service.user-registered
CORS_ORIGINS=*
