AUTH_SERVICE_NAME=auth-service
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@auth-postgres:5432/bingo_auth

USER_SERVICE_NAME=user-service
USER_WORKER_SERVICE_NAME=user-service-worker
USER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@user-postgres:5432/bingo_users

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=*

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

USER_EVENTS_EXCHANGE=user.events
USER_REGISTERED_ROUTING_KEY=user.registered
USER_REGISTERED_QUEUE=user-service.user-registered

AUTH_POSTGRES_DB=bingo_auth
AUTH_POSTGRES_USER=postgres
AUTH_POSTGRES_PASSWORD=postgres

USER_POSTGRES_DB=bingo_users
USER_POSTGRES_USER=postgres
USER_POSTGRES_PASSWORD=postgres
